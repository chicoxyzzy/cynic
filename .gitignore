# Zig build artifacts
zig-cache/
zig-out/
.zig-cache/

# Editor / OS junk
.DS_Store
*.swp
*.swo
.vscode/
.idea/

# npm scratch dir for regenerating playground/codemirror.bundle.js —
# the bundle is committed, node_modules never is. See
# playground/codemirror-entry.mjs for the regenerate command.
node_modules/

# test262 lives at vendor/test262 as a Git submodule (see .gitmodules).

# Throwaway worktree used by the gh-pages deploy flow.
.gh-pages-deploy/

# `.claude/` is mostly per-user / per-machine scratch — agent-local
# permissions (`settings.local.json`), runtime lock files
# (`scheduled_tasks.lock`), spawned worktrees (`worktrees/`),
# debugger launch configs (`launch.json`), and whatever new
# scaffolding Claude Code lands next. Ignore the whole directory
# by default; allowlist exactly the things the team actually
# shares so anything new defaults to "agent-local" without an
# edit here. Add `!.claude/<name>` when promoting a file to
# shared.
.claude/*
!.claude/commands/

# Local fuzz scratch — the nightly gate writes new-crash reproducers
# to `fuzz-artifacts/` and resumes Fuzzilli from `fuzz-storage/`
# (corpus / crashes / stats). Both are the gate's defaults when run
# locally; per-machine and never tracked. The committed knobs live in
# tools/fuzz/ (crash-baseline.txt, the scripts) and the workflow.
fuzz-artifacts/
fuzz-storage/

# `--only-failing` cache for the test262 harness — written by
# every full run, consumed by `--only-failing`.
.test262-pass-cache.txt
# Local profiling artifacts from tools/profile.sh + /profile.
# `samply load profile.json` symbolicates these into the Firefox
# Profiler UI; they're per-machine, multi-MB, and not meant to be
# tracked.
profile.json
profile.json.gz
profile.syms.json

# Bench TS tooling deps (tsgo + @types/node)
tools/bench/node_modules/
tools/bench/.remote.env
.remote.env
