  @@ -1306,6 +1310,51 @@ public class Fuzzer {
  +    /// Engine-agnostic differential: re-run the (already-succeeded)
  +    /// target sample on the reference runner and compare the fd-103
  +    /// fuzzout output of the two runs. A mismatch yields `.differential`,
  +    /// which is treated like a crash (kept + minimized). Used by the
  +    /// cynicDiff profile, where the two runs are the same cynic-fuzz
  +    /// binary at JIT vs interpreter and `--diff` makes each emit a
  +    /// completion-value digest. See docs/fuzz-differential.md.
  +    ///
  +    /// Conservative on the reference outcome: if the reference doesn't
  +    /// also succeed, we return the target execution unflagged rather
  +    /// than reporting a divergence — a reference crash/timeout is its
  +    /// own (separately-surfaced) signal and shouldn't masquerade as an
  +    /// output divergence. This keeps the lane low-noise.
  +    private func executeFuzzoutDifferential(
  +        _ execution: Execution, _ program: Program, _ script: String, withTimeout timeout: UInt32
  +    ) -> Execution {
  +        let referenceExecution = referenceRunner!.run(script, withTimeout: timeout)
  +        guard referenceExecution.outcome == .succeeded else {
  +            return execution
  +        }
  +
  +        let targetOut = execution.fuzzout.trimmingCharacters(in: .whitespacesAndNewlines)
  +        let referenceOut = referenceExecution.fuzzout.trimmingCharacters(
  +            in: .whitespacesAndNewlines)
  +
  +        if targetOut == referenceOut {
  +            return execution
  +        }
  +
  +        logger.error(
  +            """
  +            ================================================================
  +            [CYNIC-DIFF]  OUTPUT DIVERGENCE
  +            === TARGET fuzzout ===
  +            \(targetOut)
  +            === REFERENCE fuzzout ===
  +            \(referenceOut)
  +            === SCRIPT ===
  +            \(script)
  +            ================================================================
  +            """)
  +
  +        return DiffExecution.fuzzoutDivergence(target: execution, reference: referenceExecution)
  +    }
  +
       private func executeDifferentialIfNeeded(
           _ execution: Execution, _ program: Program, _ script: String, withTimeout timeout: UInt32
       ) -> Execution {
